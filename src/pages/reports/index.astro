---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { slugFor } from '../../lib/reports';

const fonts =
  'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap';

const reports = (await getCollection('reports')).map((r) => ({ ...r, slug: slugFor(r.id) }));
const sorted = [...reports].sort((a, b) => b.data.date_iso.localeCompare(a.data.date_iso));
const featured = reports.reduce((best, r) => (best == null || r.data.phi_s > best.data.phi_s ? r : best), null as (typeof reports)[number] | null);
const base = import.meta.env.BASE_URL;

function formatLong(iso: string): string {
  const d = new Date(iso);
  return isNaN(d.getTime()) ? iso : d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
function formatShort(iso: string): string {
  const d = new Date(iso);
  return isNaN(d.getTime()) ? iso : d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase();
}
---

<Layout
  title="Signal Reports — Eigenstate Research"
  description="Topology signal reports for the tokenized settlement layer. 197 entities, real-time settlement pressure and curl detection. E = ΔI/A."
  fonts={fonts}
>
  <Fragment slot="head">
    <style>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-body);
        font-weight: 300;
        background: var(--bg);
        color: var(--text-primary);
        line-height: 1.7;
      }

      /* ── Page hero ── */
      .page-hero {
        padding: 80px 40px 64px;
        text-align: center;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, rgb(10 14 39 / 60%) 0%, transparent 100%);
      }

      .page-hero .eyebrow {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: 600;
        letter-spacing: 0.3em;
        color: var(--orange);
        margin-bottom: 16px;
        text-transform: uppercase;
      }

      .page-hero h1 {
        font-family: var(--font-heading);
        font-size: var(--text-5xl);
        font-weight: 900;
        letter-spacing: 0.08em;
        line-height: 1;
        margin-bottom: 24px;
        background: linear-gradient(135deg, var(--text-primary) 0%, var(--cyan) 60%, var(--text-primary) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .page-hero .explainer {
        font-size: var(--text-base);
        color: var(--text-secondary);
        max-width: 640px;
        margin: 0 auto 36px;
        line-height: 1.7;
      }

      /* ── Sections ── */
      section {
        padding: 64px 40px;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
      }

      .eyebrow {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: 600;
        letter-spacing: 0.25em;
        color: var(--cyan);
        text-transform: uppercase;
        margin-bottom: 12px;
      }

      .section-title {
        font-family: var(--font-heading);
        font-size: var(--text-2xl);
        font-weight: 800;
        letter-spacing: 0.05em;
        margin-bottom: 8px;
      }

      .section-sub {
        font-size: var(--text-sm);
        color: var(--text-muted);
        margin-bottom: 40px;
        font-family: var(--font-mono);
      }

      .divider {
        width: 60px;
        height: 2px;
        background: linear-gradient(90deg, var(--cyan-dim), transparent);
        margin-bottom: 40px;
      }

      .grad {
        background: linear-gradient(135deg, var(--orange), var(--status-error));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* ── Featured hero card ── */
      .featured-section {
        background: var(--bg2);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }

      .featured-loading {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--text-muted);
        letter-spacing: 0.15em;
      }

      .featured-card {
        background: var(--bg-card);
        border: 1px solid var(--border-strong);
        border-left: 4px solid var(--orange);
        padding: 48px;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 48px;
        align-items: center;
        text-decoration: none;
        transition: border-color 0.2s;
      }

      .featured-card:hover {
        border-left-color: var(--status-error);
      }

      .fc-badge {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: 600;
        letter-spacing: 0.2em;
        color: var(--orange);
        text-transform: uppercase;
        margin-bottom: 16px;
      }

      .fc-entity {
        font-family: var(--font-heading);
        font-size: var(--text-3xl);
        font-weight: 800;
        letter-spacing: 0.04em;
        color: var(--text-primary);
        margin-bottom: 20px;
        line-height: 1.1;
      }

      .fc-meta {
        display: flex;
        gap: 32px;
        align-items: center;
        flex-wrap: wrap;
      }

      .fc-phi {
        font-family: var(--font-mono);
        font-size: var(--text-xl);
        font-weight: 600;
        color: var(--orange);
        text-shadow: 0 0 20px rgb(255 107 53 / 30%);
      }

      .fc-kappa {
        font-family: var(--font-mono);
        font-size: var(--text-xl);
        font-weight: 600;
        color: var(--cyan);
        text-shadow: 0 0 20px rgb(0 217 255 / 20%);
      }

      .fc-vault {
        font-family: var(--font-mono);
        font-size: var(--text-lg);
        color: var(--status-success);
      }

      .fc-label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--text-muted);
        letter-spacing: 0.1em;
        margin-bottom: 4px;
      }

      .fc-right {
        text-align: right;
      }

      .fc-date {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--text-muted);
        margin-bottom: 20px;
      }

      .fc-read {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        font-weight: 600;
        letter-spacing: 0.1em;
        padding: 14px 28px;
        background: var(--orange);
        color: #fff;
        text-decoration: none;
        display: inline-block;
        border-radius: var(--radius-sm);
        transition: all 0.2s;
      }

      .fc-read:hover {
        background: #e85a20;
        transform: translateY(-1px);
      }

      /* ── Reports filter bar ── */
      .reports-filter-bar {
        display: flex;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
      }

      .reports-search {
        flex: 1;
        min-width: 200px;
        font-family: var(--font-body);
        font-size: var(--text-sm);
        padding: 12px 16px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        color: var(--text-primary);
      }

      .reports-search::placeholder {
        color: var(--text-muted);
      }

      .reports-search:focus {
        outline: none;
        border-color: var(--orange);
        box-shadow: 0 0 0 3px rgb(255 107 53 / 15%);
      }

      .reports-sort {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        padding: 12px 16px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        color: var(--text-primary);
        cursor: pointer;
      }

      .reports-empty {
        padding: 48px;
        text-align: center;
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--text-muted);
        border: 1px solid var(--border);
        border-top: none;
      }

      /* ── Reports grid ── */
      .reports-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
      }

      .report-card {
        background: var(--bg);
        padding: 28px;
        text-decoration: none;
        display: block;
        border-left: 3px solid transparent;
        transition: all 0.2s;
      }

      .report-card:hover {
        background: var(--bg-card);
        border-left-color: var(--orange);
      }

      .rc-entity {
        font-family: var(--font-heading);
        font-size: var(--text-sm);
        font-weight: 700;
        letter-spacing: 0.04em;
        color: var(--text-primary);
        margin-bottom: 14px;
        line-height: 1.3;
      }

      .rc-metrics {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 12px;
      }

      .rc-phi {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: 600;
        color: var(--orange);
        background: rgb(255 107 53 / 10%);
        padding: 3px 8px;
        border-radius: var(--radius-sm);
      }

      .rc-kappa {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--cyan);
        background: rgb(0 217 255 / 8%);
        padding: 3px 8px;
        border-radius: var(--radius-sm);
      }

      .rc-vault {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--status-success);
        background: rgb(34 197 94 / 8%);
        padding: 3px 8px;
        border-radius: var(--radius-sm);
      }

      .rc-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .rc-date {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--text-muted);
      }

      .rc-cta {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--cyan-dim);
      }

      /* ── Tiers ── */
      .tiers-section {
        background: var(--bg2);
        border-top: 1px solid var(--border);
      }

      .tiers-list {
        display: flex;
        flex-direction: column;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
      }

      .tier {
        background: var(--bg);
        padding: 32px 36px;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 2rem;
        align-items: start;
        border-left: 3px solid transparent;
        transition: all 0.2s;
      }

      .tier:hover {
        background: var(--bg-card);
        border-left-color: var(--cyan-dim);
      }

      .tier-name {
        font-family: var(--font-heading);
        font-size: var(--text-sm);
        font-weight: 700;
        letter-spacing: 0.05em;
        color: var(--text-primary);
        margin-bottom: 10px;
      }

      .tier-desc {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        line-height: 1.7;
        max-width: 640px;
      }

      .tier-inc {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--text-muted);
        margin-top: 10px;
        letter-spacing: 0.03em;
      }

      .tier-price {
        font-family: var(--font-mono);
        font-size: var(--text-xl);
        font-weight: 600;
        color: var(--orange);
        white-space: nowrap;
        text-align: right;
        text-shadow: 0 0 15px rgb(255 107 53 / 20%);
      }

      .tier-unit {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--text-muted);
        text-align: right;
        margin-top: 4px;
      }

      /* ── Request form ── */
      .request-section {
        border-top: 1px solid var(--border);
      }

      .request-heading {
        text-align: center;
        margin-bottom: 40px;
      }

      .request-eyebrow {
        justify-content: center;
        display: flex;
      }

      .request-title {
        font-size: var(--text-2xl);
      }

      .request-sub {
        font-size: var(--text-base);
        color: var(--text-secondary);
        margin-top: 12px;
        line-height: 1.8;
      }

      .form-wrap {
        background: var(--bg-card);
        border: 1px solid var(--border-strong);
        border-radius: var(--radius-sm);
        padding: 48px;
        max-width: 760px;
        margin: 0 auto;
      }

      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
      }

      .form-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 20px;
      }

      .form-group label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.15em;
        color: var(--text-muted);
        margin-bottom: 8px;
        text-transform: uppercase;
      }

      .form-group input,
      .form-group select,
      .form-group textarea {
        font-family: var(--font-body);
        font-size: var(--text-base);
        padding: 14px 16px;
        background: rgb(3 7 18 / 80%);
        border: 1px solid rgb(148 163 184 / 20%);
        border-radius: var(--radius-sm);
        color: var(--text-primary);
        transition: border-color 0.2s;
      }

      .form-group input:focus,
      .form-group select:focus,
      .form-group textarea:focus {
        outline: none;
        border-color: var(--orange);
        box-shadow: 0 0 0 3px rgb(255 107 53 / 15%);
      }

      .form-group input::placeholder,
      .form-group textarea::placeholder {
        color: var(--text-muted);
      }

      .form-group select {
        cursor: pointer;
      }

      .form-group select option {
        background: var(--bg-card);
      }

      .form-wrap .btn {
        margin-top: 8px;
      }

      .form-msg {
        text-align: center;
        margin-top: 16px;
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        min-height: 20px;
      }

      .form-msg.ok {
        color: var(--status-success);
      }

      .form-msg.err {
        color: var(--orange);
      }

      .form-note {
        text-align: center;
        margin-top: 20px;
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--text-muted);
      }

      .form-note a {
        color: var(--cyan-dim);
        text-decoration: none;
      }

      /* ── Responsive ── */
      @media (width <= 900px) {
        .reports-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (width <= 640px) {
        .page-hero {
          padding: 56px 20px 48px;
        }

        .page-hero h1 {
          font-size: var(--text-2xl);
        }

        section {
          padding: 48px 20px;
        }

        .featured-card {
          grid-template-columns: 1fr;
          gap: 24px;
        }

        .fc-right {
          text-align: left;
        }

        .fc-entity {
          font-size: var(--text-xl);
        }

        .reports-grid {
          grid-template-columns: 1fr;
        }

        .tier {
          grid-template-columns: 1fr;
        }

        .tier-price {
          text-align: left;
        }

        .form-row {
          grid-template-columns: 1fr;
        }

        .form-wrap {
          padding: 28px 20px;
        }
      }
    </style>
  </Fragment>

  <Nav active="reports" cta={{ label: 'Request Report', href: '#request' }} />

  <!-- ── Page hero ── -->
  <div class="page-hero" id="main">
    <div class="eyebrow">EIGENSTATE RESEARCH · TOPOLOGY SIGNAL REPORTS</div>
    <h1>SIGNAL REPORTS</h1>
    <p class="explainer">
      Real-time topology measurements of the tokenized settlement layer — settlement pressure,
      field coherence, and information flow quantified across 197 entities.
    </p>
    <a href="#request" class="btn btn-lg btn-gradient">Request a Report →</a>
  </div>

  <!-- ── Featured: highest Φ_S ── -->
  <section class="featured-section">
    <div class="container">
      <div class="eyebrow">HIGHEST SETTLEMENT PRESSURE · FEATURED REPORT</div>
      {
        featured ? (
          <a href={`${base}reports/${featured.slug}/`} class="featured-card">
            <div>
              <div class="fc-badge">Settlement Pressure · Top Entity</div>
              <div class="fc-entity">{featured.data.entity_display}</div>
              <div class="fc-meta">
                <div>
                  <div class="fc-label">Settlement Pressure</div>
                  <div class="fc-phi">Φ_S = {featured.data.phi_s.toFixed(4)}</div>
                </div>
                <div>
                  <div class="fc-label">Field Coherence</div>
                  <div class="fc-kappa">κ = {featured.data.kappa.toFixed(4)}</div>
                </div>
                <div>
                  <div class="fc-label">Vault Records</div>
                  <div class="fc-vault">{featured.data.vault_records} observations</div>
                </div>
              </div>
            </div>
            <div class="fc-right">
              <div class="fc-date">{formatLong(featured.data.date_iso)}</div>
              <span class="fc-read">Read Report →</span>
            </div>
          </a>
        ) : (
          <div class="featured-loading">No reports published yet.</div>
        )
      }
    </div>
  </section>

  <!-- ── All reports list ── -->
  <section>
    <div class="container">
      <div class="eyebrow">ALL SIGNAL REPORTS</div>
      <h2 class="section-title">Latest <span class="grad">measurements</span></h2>
      <div class="section-sub">
        Engine-generated field position reports. Updated each cycle. {sorted.length} published.
      </div>

      <div class="reports-filter-bar">
        <input
          type="text"
          id="reportsSearch"
          class="reports-search"
          placeholder="Search by entity name…"
          aria-label="Search reports by entity name"
        />
        <select id="reportsSort" class="reports-sort" aria-label="Sort reports">
          <option value="newest">Newest first</option>
          <option value="phi-desc">Highest Φ_S</option>
        </select>
      </div>

      <div class="reports-grid" id="reportsGrid">
        {
          sorted.map((r) => (
            <a
              href={`${base}reports/${r.slug}/`}
              class="report-card"
              data-entity={r.data.entity_display}
              data-phi-s={r.data.phi_s}
              data-date-iso={r.data.date_iso}
            >
              <div class="rc-entity">{r.data.entity_display}</div>
              <div class="rc-metrics">
                <span class="rc-phi">Φ_S {r.data.phi_s.toFixed(3)}</span>
                <span class="rc-kappa">κ {r.data.kappa.toFixed(3)}</span>
                {r.data.vault_records > 0 && <span class="rc-vault">{r.data.vault_records} obs</span>}
              </div>
              <div class="rc-footer">
                <span class="rc-date">{formatShort(r.data.date_iso)}</span>
                <span class="rc-cta">Read →</span>
              </div>
            </a>
          ))
        }
      </div>
      <div class="reports-empty" id="reportsEmpty" style="display: none;">No reports match your search.</div>
    </div>
  </section>

  <!-- ── Pricing tiers ── -->
  <section class="tiers-section">
    <div class="container">
      <div class="eyebrow">REPORTS</div>
      <h2 class="section-title">The information field, <span class="grad">made visible.</span></h2>
      <div class="divider"></div>
      <div class="tiers-list">
        <div class="tier">
          <div>
            <div class="tier-name">SINGLE ENTITY REPORT</div>
            <div class="tier-desc">
              Full topology analysis of one entity: extraction pressure (Γ), loop membership, curl
              wave state, N+1 trajectory, settlement pain (Φ_S). PDF + raw JSON within 24 hours.
            </div>
            <div class="tier-inc">
              Includes: Γ score · loop velocity · curl state · N+1 prediction · settlement path ·
              EAS attestation
            </div>
          </div>
          <div><div class="tier-price">$59</div><div class="tier-unit">per entity</div></div>
        </div>
        <div class="tier">
          <div>
            <div class="tier-name">SECTOR REPORT — INFORMATION FLOW</div>
            <div class="tier-desc">
              Full analysis of the information flow sector: 164 entities, 158 currently breaking,
              Φ_S scores, loop velocity rankings, recommended positions. Updated weekly on atomic
              cycle.
            </div>
            <div class="tier-inc">
              Includes: full sector map · weekly Δ · top breaking entities · forming loops · field
              equations
            </div>
          </div>
          <div><div class="tier-price">$490</div><div class="tier-unit">per month</div></div>
        </div>
        <div class="tier">
          <div>
            <div class="tier-name">CUSTOM TOPOLOGY BRIEFING</div>
            <div class="tier-desc">
              Bespoke analysis for your investment thesis, regulatory question, or infrastructure
              positioning. Includes methodology session and engine output for the engagement
              period.
            </div>
            <div class="tier-inc">
              Includes: custom entity set · methodology session · engine output · follow-up Q&A
            </div>
          </div>
          <div><div class="tier-price">$2,400</div><div class="tier-unit">per engagement</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Request a Report ── -->
  <section class="request-section" id="request">
    <div class="container">
      <div class="request-heading">
        <div class="eyebrow request-eyebrow">REQUEST A REPORT</div>
        <h2 class="section-title request-title">
          Get the topology read on<br /><span class="grad">your entity or sector.</span>
        </h2>
        <p class="request-sub">Tell us what you're tracking. Response within 24 hours.</p>
      </div>
      <div class="form-wrap">
        <div class="form-row">
          <div class="form-group"><label for="fn">Name</label><input type="text" id="fn" placeholder="Your name" /></div>
          <div class="form-group">
            <label for="fe">Email</label><input type="email" id="fe" placeholder="your@email.com" required />
          </div>
        </div>
        <div class="form-group">
          <label for="fo">Organization</label><input type="text" id="fo" placeholder="Fund / firm / independent" />
        </div>
        <div class="form-group">
          <label for="ft">Report type</label>
          <select id="ft">
            <option value="" disabled selected>Select report type</option>
            <option>Single entity report — $59</option>
            <option>Sector report — $490/month</option>
            <option>Custom briefing — $2,400</option>
            <option>Not sure — send me a sample</option>
          </select>
        </div>
        <div class="form-group">
          <label for="fent">Entity or sector of interest</label>
          <textarea
            id="fent"
            rows="3"
            placeholder="e.g. Circle, Coinbase, OCC regulatory loop, GENIUS Act implementation, stablecoin issuance layer…"
          ></textarea>
        </div>
        <button class="btn btn-md btn-block" id="submitBtn" type="button">
          REQUEST REPORT
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"
            ><path
              d="M3 8h10M8 3l5 5-5 5"
              stroke="white"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path></svg
          >
        </button>
        <div class="form-msg" id="msg"></div>
        <p class="form-note">Or email: <a href="mailto:ksekhon9851@Gmail.com">ksekhon9851@Gmail.com</a></p>
      </div>
    </div>
  </section>

  <Footer variant="full" />

  <script>
    import { initReveal } from '../../scripts/reveal';
    import { initFilterList } from '../../scripts/filter-list';

    initReveal({ selector: '.featured-card, .report-card' });

    initFilterList({
      containerSelector: '#reportsGrid',
      itemSelector: '.report-card',
      searchInputSelector: '#reportsSearch',
      searchFields: ['entity'],
      sortSelectSelector: '#reportsSort',
      sortOptions: {
        newest: { field: 'dateIso', direction: 'desc', type: 'string' },
        'phi-desc': { field: 'phiS', direction: 'desc', type: 'number' },
      },
      emptyStateSelector: '#reportsEmpty',
    });

    async function submitForm() {
      const eInput = document.getElementById('fe') as HTMLInputElement;
      const e = eInput.value.trim();
      const msg = document.getElementById('msg')!;
      if (!e || !e.includes('@')) {
        msg.textContent = 'Please enter a valid email.';
        msg.className = 'form-msg err';
        return;
      }
      msg.textContent = 'Sending…';
      msg.className = 'form-msg';
      try {
        const r = await fetch('https://formspree.io/f/xgoprgww', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            name: (document.getElementById('fn') as HTMLInputElement).value,
            email: e,
            organization: (document.getElementById('fo') as HTMLInputElement).value,
            report_type: (document.getElementById('ft') as HTMLSelectElement).value,
            entity_interest: (document.getElementById('fent') as HTMLTextAreaElement).value,
            _subject: 'Eigenstate — signal report request',
          }),
        });
        if (r.ok) {
          msg.textContent = 'Received. Response within 24 hours. — Eigenstate Research';
          msg.className = 'form-msg ok';
        } else {
          msg.textContent = 'Something went wrong. Email ksekhon9851@Gmail.com directly.';
          msg.className = 'form-msg err';
        }
      } catch (_) {
        msg.textContent = 'Network error. Email ksekhon9851@Gmail.com directly.';
        msg.className = 'form-msg err';
      }
    }

    document.getElementById('submitBtn')?.addEventListener('click', submitForm);
  </script>
</Layout>
