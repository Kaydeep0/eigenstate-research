    <!-- Scripts -->
    <script>
      import { BinaryTunnel } from '../scripts/binary-tunnel.js';
      import { ScrollAnimations } from '../scripts/scroll-animations.js';
      import { initNavigation, initMobileNavToggle } from '../scripts/nav';
      import { initForm } from '../scripts/form';
      import { initMiniCharts, initNetworkCanvas } from '../scripts/mini-charts';

      document.addEventListener('DOMContentLoaded', () => {
        const loadingText = document.getElementById('loadingText');
        if (loadingText) {
          const text = 'INITIALIZING...';
          loadingText.textContent = '';
          let i = 0;
          const typeInterval = setInterval(() => {
            if (i < text.length) {
              loadingText.textContent += text[i];
              i++;
            } else {
              clearInterval(typeInterval);
            }
          }, 25);
        }

        // Hero background: 3D binary corridor
        if (document.getElementById('binary-rain-canvas')) {
          (window as any).binaryTunnel = new BinaryTunnel('binary-rain-canvas');
        }

        (window as any).scrollAnimations = new ScrollAnimations();
        initMiniCharts();
        initNetworkCanvas();
        initNavigation();
        initMobileNavToggle('navToggle', 'navLinks');
        initForm({
          formId: 'accessForm',
          endpoint: 'https://formspree.io/f/xgoprgww',
          subject: 'Eigenstate — institutional access request (root site)',
          fieldIds: ['name', 'email', 'organization'],
        });
      });
    </script>
