---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import commits from '../../data/helix_commits.json';

const base = import.meta.env.BASE_URL;

const fonts =
  'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap';

interface Commit {
  block_number: number | null;
  committed_at: string;
  n_crossings: number | null;
  chain_valid: boolean | null;
  tx_hash: string | null;
  basescan_url?: string;
}

function formatDate(iso: string): string {
  const d = new Date(iso);
  return isNaN(d.getTime()) ? iso || '—' : d.toISOString().replace('T', ' ').slice(0, 16) + ' UTC';
}

function shortHash(h: string | null): string {
  if (!h) return '—';
  return h.slice(0, 8) + '…' + h.slice(-6);
}

const sorted = [...(commits as Commit[])].sort(
  (a, b) => new Date(b.committed_at || 0).getTime() - new Date(a.committed_at || 0).getTime()
);
const validCount = sorted.filter((c) => c.chain_valid === true).length;
---

<Layout
  title="On-Chain Proof Index — Eigenstate Research"
  description="Every field-state fingerprint committed to Base mainnet — timestamped before external confirmation, verifiable on Basescan."
  fonts={fonts}
>
  <Fragment slot="head">
    <style>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: var(--font-body);
        font-weight: 300;
        background: var(--bg);
        color: var(--text-primary);
        line-height: 1.7;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 60px 40px;
      }

      @media (width <= 640px) {
        .container {
          padding: 40px 20px;
        }
      }

      .eyebrow {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: 600;
        letter-spacing: 0.25em;
        color: var(--signal);
        text-transform: uppercase;
        margin-bottom: 12px;
      }

      .page-title {
        font-family: var(--font-heading);
        font-size: clamp(24px, 3vw, 36px);
        font-weight: 800;
        letter-spacing: 0.08em;
        margin-bottom: 24px;
      }

      .explanation {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-left: 3px solid var(--signal);
        border-radius: var(--radius-md);
        padding: 20px 24px;
        margin-bottom: 24px;
        font-size: var(--text-sm);
        color: var(--text-secondary);
        line-height: 1.7;
      }

      .explanation code {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--signal);
        background: rgb(47 90 99 / 8%);
        padding: 2px 6px;
        border-radius: var(--radius-sm);
        overflow-wrap: break-word;
      }

      .stats-row {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
        margin-bottom: 32px;
      }

      .stat-inline {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--text-secondary);
      }

      .stat-inline strong {
        color: var(--text-primary);
      }

      .table-wrap {
        overflow-x: auto;
        border: 1px solid var(--border-strong);
        border-radius: var(--radius-lg);
      }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: var(--text-sm);
      }

      thead tr {
        background: var(--bg2);
      }

      th {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text-muted);
        padding: 14px 16px;
        text-align: left;
        border-bottom: 1px solid var(--border-live);
        white-space: nowrap;
      }

      .th-num {
        text-align: right;
      }

      td {
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
      }

      tr:last-child td {
        border-bottom: none;
      }

      tbody tr:nth-child(even) td {
        background: rgb(0 0 0 / 3%);
      }

      tr:hover td {
        background: rgb(148 163 184 / 6%);
      }

      .cell-block {
        font-family: var(--font-mono);
        font-weight: 600;
        color: var(--text-primary);
      }

      .cell-date {
        font-family: var(--font-mono);
        color: var(--text-secondary);
        white-space: nowrap;
      }

      .cell-crossings {
        font-family: var(--font-mono);
        font-variant-numeric: tabular-nums;
        text-align: right;
        color: var(--text-secondary);
      }

      .cell-hash {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--text-muted);
      }

      .basescan-link {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--signal);
        text-decoration: none;
      }

      .basescan-link:hover {
        text-decoration: underline;
      }

      .status {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: 600;
        letter-spacing: 0.03em;
        white-space: nowrap;
      }

      .status::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentcolor;
        flex-shrink: 0;
      }

      .status-valid {
        color: var(--status-success);
      }

      .status-invalid {
        color: var(--status-error);
      }

      td.no-data {
        text-align: center;
        font-style: italic;
        color: var(--text-muted);
        padding: 48px;
      }

      .page-footer-note {
        margin-top: 24px;
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--text-muted);
        line-height: 1.8;
      }

      .page-footer-note a {
        color: var(--text-secondary);
        text-decoration: none;
      }

      .page-footer-note a:hover {
        color: var(--signal);
      }
    </style>
  </Fragment>

  <Nav active="onchain" />

  <div class="container" id="main">
    <div class="eyebrow">EIGENSTATE RESEARCH · ON-CHAIN PROOF</div>
    <h1 class="page-title">ON-CHAIN PROOF INDEX</h1>

    <div class="explanation">
      Each row is a fingerprint committed to Base mainnet. The fingerprint is a SHA-256 hash of the
      observation state at the time of measurement: entity field values, loop detections, and
      cycle metrics. Publishing the fingerprint before external confirmation means the timestamp
      is immutable. Verify any claim by looking up the block on Basescan.
      <br /><br />
      Contract: <code>0x3A2d6599d5409c1A87609c38dB9b1619e47F6b02</code> (Base)
    </div>

    <div class="stats-row">
      <div class="stat-inline"><strong>{sorted.length}</strong> commits recorded</div>
      <div class="stat-inline"><strong>{validCount}</strong> chain-verified valid</div>
    </div>

    <div class="table-wrap bracket">
      <table id="commits-table">
        <thead>
          <tr>
            <th>Block</th>
            <th>Date (UTC)</th>
            <th class="th-num">Crossings</th>
            <th>Chain</th>
            <th>Transaction</th>
            <th>Basescan</th>
          </tr>
        </thead>
        <tbody id="commits-tbody">
          {
            sorted.length === 0 ? (
              <tr><td colspan="6" class="no-data">No commits recorded yet.</td></tr>
            ) : (
              sorted.map((c) => {
                const valid = c.chain_valid;
                const url = c.basescan_url || (c.tx_hash ? 'https://basescan.org/tx/' + c.tx_hash : '#');
                return (
                  <tr>
                    <td class="cell-block">{c.block_number ?? '—'}</td>
                    <td class="cell-date">{formatDate(c.committed_at)}</td>
                    <td class="cell-crossings">{c.n_crossings ?? '—'}</td>
                    <td>
                      {valid === true ? (
                        <span class="status status-valid">valid</span>
                      ) : valid === false ? (
                        <span class="status status-invalid">invalid</span>
                      ) : (
                        <span class="cell-hash">—</span>
                      )}
                    </td>
                    <td class="cell-hash" title={c.tx_hash ?? ''}>{shortHash(c.tx_hash)}</td>
                    <td><a class="basescan-link" href={url} target="_blank" rel="noopener">view ↗</a></td>
                  </tr>
                );
              })
            )
          }
        </tbody>
      </table>
    </div>

    <p class="page-footer-note">
      Data source: <a href={`${base}api/onchain.json`}>onchain.json</a> — updated each parkash cycle.
      Methodology: <a href={`${base}METHODOLOGY.md`}>METHODOLOGY.md</a> ·
      <a href="https://github.com/Kaydeep0/eigenstate-research" target="_blank" rel="noopener">GitHub</a>
    </p>
  </div>

  <Footer variant="minimal" note="This page is generated automatically from engine output. Not financial advice." />
</Layout>
