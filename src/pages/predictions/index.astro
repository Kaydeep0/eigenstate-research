---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PredictionCard from '../../components/PredictionCard.astro';

const fonts =
  'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap';

const predictions = (await getCollection('predictions')).sort((a, b) =>
  b.data.logged_at.localeCompare(a.data.logged_at)
);

const stats = {
  total: predictions.length,
  pending: predictions.filter((p) => p.data.status === 'pending').length,
  confirmed: predictions.filter((p) => p.data.status === 'confirmed').length,
  refuted: predictions.filter((p) => p.data.status === 'refuted').length,
  maxGapScore: Math.max(...predictions.map((p) => p.data.engine_signal.gap_score)),
};
---

<Layout
  title="Predictions — Eigenstate Research"
  description="Structural gap predictions logged before outcome is known. Each entry is timestamped and committed to Base mainnet before publication. Falsifiable claims about the tokenized finance settlement layer."
  fonts={fonts}
>
  <Fragment slot="head">
    <style>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-body);
        font-weight: 300;
        background: var(--bg);
        color: var(--text-primary);
        line-height: 1.7;
      }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 60px 40px;
      }

      .page-header {
        margin-bottom: 48px;
      }

      .page-title {
        font-family: var(--font-heading);
        font-size: clamp(22px, 3vw, 34px);
        font-weight: 800;
        letter-spacing: 0.08em;
        margin-bottom: 8px;
      }

      .page-sub {
        color: var(--text-secondary);
        font-size: var(--text-base);
        max-width: 680px;
        line-height: 1.6;
        margin-top: 12px;
      }

      .stats-row {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 48px;
      }

      .stat-pill {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 16px 24px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 140px;
      }

      .stat-pill .label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.08em;
        color: var(--text-muted);
        text-transform: uppercase;
      }

      .stat-pill .value {
        font-family: var(--font-heading);
        font-size: var(--text-lg);
        font-weight: 700;
        color: var(--signal);
      }

      .stat-pill .value-amber {
        color: var(--status-warning);
      }

      .stat-pill .value-green {
        color: var(--status-success);
      }

      .stat-pill .value-muted {
        color: var(--text-muted);
      }

      .stat-pill .value-t1 {
        color: var(--text-primary);
      }

      .stat-pill .note {
        font-size: var(--text-xs);
        color: var(--text-muted);
      }

      .method-block {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 32px;
        margin-top: 48px;
      }

      .method-block h3 {
        font-family: var(--font-heading);
        font-size: var(--text-sm);
        font-weight: 700;
        letter-spacing: 0.08em;
        margin-bottom: 20px;
        color: var(--text-secondary);
        text-transform: uppercase;
      }

      .method-beats {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .method-beat {
        display: grid;
        grid-template-columns: 32px 1fr;
        gap: 16px;
        align-items: start;
      }

      .method-beat .beat-marker {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: 600;
        color: var(--accent-dark);
        letter-spacing: 0.05em;
        padding-top: 2px;
      }

      .method-beat p {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        line-height: 1.7;
      }

      @media (width <= 640px) {
        .method-beat {
          grid-template-columns: 24px 1fr;
          gap: 12px;
        }
      }

      .method-block code {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--signal);
        background: rgb(47 90 99 / 8%);
        padding: 2px 6px;
        border-radius: var(--radius-sm);
      }

      .method-block strong {
        color: var(--text-primary);
        display: block;
        margin-bottom: 4px;
      }

      .method-block a {
        color: var(--signal);
      }

      .section-title {
        font-family: var(--font-heading);
        font-size: var(--text-sm);
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-bottom: 20px;
        margin-top: 48px;
        border-top: 1px solid var(--border);
        padding-top: 32px;
      }

      /* Sliding carousel — one prediction card in full focus at a time
         instead of three dense cards stacked in an endless scroll. The
         track is a real scroll container (scroll-snap-type), so touch swipe
         and keyboard scrolling work natively; JS only syncs the arrow
         buttons/dots to scroll position. */
      .predictions-carousel {
        position: relative;
      }

      .carousel-track {
        display: flex;
        gap: 24px;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        padding-bottom: 4px;
        scrollbar-width: none;
      }

      .carousel-track::-webkit-scrollbar {
        display: none;
      }

      @media (prefers-reduced-motion: reduce) {
        .carousel-track {
          scroll-behavior: auto;
        }
      }

      .carousel-slide {
        flex: 0 0 100%;
        min-width: 0;
        scroll-snap-align: start;
      }

      .carousel-controls {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 18px;
        margin-top: 24px;
      }

      .carousel-arrow {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        border: 1px solid var(--border-strong);
        background: var(--bg-card);
        color: var(--text-primary);
        font-family: var(--font-mono);
        font-size: 15px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        transition:
          border-color 0.2s ease,
          color 0.2s ease;
      }

      .carousel-arrow:hover:not(:disabled) {
        border-color: var(--accent);
        color: var(--accent);
      }

      .carousel-arrow:disabled {
        opacity: 0.35;
        cursor: not-allowed;
      }

      .carousel-dots {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .carousel-dot {
        width: 8px;
        height: 8px;
        padding: 0;
        border: none;
        border-radius: 50%;
        background: var(--border-strong);
        cursor: pointer;
        transition:
          background 0.2s ease,
          transform 0.2s ease;
      }

      .carousel-dot.active {
        background: var(--accent);
        transform: scale(1.35);
      }

      @media (width <= 640px) {
        .container {
          padding: 40px 20px;
        }
      }
    </style>
  </Fragment>

  <Nav active="predictions" />

  <div class="container" id="main">
    <div class="page-header">
      <h1 class="page-title">STRUCTURAL PREDICTIONS</h1>
      <p class="page-sub">
        Gap-level predictions logged before any public claim is made. Each entry is timestamped,
        falsifiable, and committed to Base mainnet before publication. The engine does not
        post-explain events. It names them first.
      </p>
    </div>

    <div class="stats-row">
      <div class="stat-pill">
        <div class="label">Total</div>
        <div class="value">{stats.total}</div>
        <div class="note">formal predictions</div>
      </div>
      <div class="stat-pill">
        <div class="label">Pending</div>
        <div class="value value-amber">{stats.pending}</div>
        <div class="note">awaiting outcome</div>
      </div>
      <div class="stat-pill">
        <div class="label">Confirmed</div>
        <div class="value value-green">{stats.confirmed}</div>
        <div class="note">&nbsp;</div>
      </div>
      <div class="stat-pill">
        <div class="label">Refuted</div>
        <div class="value value-muted">{stats.refuted}</div>
        <div class="note">&nbsp;</div>
      </div>
      <div class="stat-pill">
        <div class="label">Max Gap Score</div>
        <div class="value">{stats.maxGapScore.toFixed(1)}</div>
        <div class="note">FED / LIBOR</div>
      </div>
      <div class="stat-pill">
        <div class="label">Markets Covered</div>
        <div class="value value-t1">3</div>
        <div class="note">US rates · India derivatives</div>
      </div>
    </div>

    <div class="section-title">Active Predictions</div>

    <div class="predictions-carousel">
      <div class="carousel-track" id="predictionsTrack">
        {predictions.map((p) => (
          <div class="carousel-slide">
            <PredictionCard {...p.data} />
          </div>
        ))}
      </div>
      <div class="carousel-controls">
        <button class="carousel-arrow" id="predPrev" aria-label="Previous prediction" type="button">←</button>
        <div class="carousel-dots" id="predDots">
          {predictions.map((_, i) => (
            <button class="carousel-dot" aria-label={`Go to prediction ${i + 1}`} type="button" />
          ))}
        </div>
        <button class="carousel-arrow" id="predNext" aria-label="Next prediction" type="button">→</button>
      </div>
    </div>

    <div class="method-block">
      <h3>Methodology</h3>
      <div class="method-beats">
        <div class="method-beat">
          <span class="beat-marker">01</span>
          <p>
            <strong>What is a structural prediction?</strong>
            A structural prediction identifies a gap between what a market structure currently prices
            and what the underlying settlement mechanics require. It is not a price call. It is a
            claim that a specific structural fragility exists and will manifest during stress. The
            engine surfaces these via <code>liquidity_gap_detector.py</code>, which computes
            gap_ratio = notional exposure / daily settlement volume.
          </p>
        </div>
        <div class="method-beat">
          <span class="beat-marker">02</span>
          <p>
            <strong>Logging protocol</strong>
            Each prediction is written to <code>predictions/predictions.json</code> before any public
            statement is made. The engine state at that moment is committed to Base mainnet via the
            GeniusFlow Settlement Contract. The on-chain block timestamp is the proof of priority: the
            prediction existed before the outcome was observable.
          </p>
        </div>
        <div class="method-beat">
          <span class="beat-marker">03</span>
          <p>
            <strong>Falsifiability requirement</strong>
            Every entry must include an explicit falsifiable condition: a specific observable event
            that would either confirm or refute the prediction. Entries without a falsifiable
            condition are not logged. The prediction window is open-ended for structural predictions
            (no arbitrary 30-day cutoff, since these gaps can persist for years before resolution).
          </p>
        </div>
        <div class="method-beat">
          <span class="beat-marker">04</span>
          <p>
            <strong>Gap score</strong>
            Normalized 0-10 scale. 10.0 is the maximum, assigned when gap_ratio exceeds 100:1 and
            settlement_leverage_normalized exceeds 8×. LIBOR_EQUIVALENT is the first prediction logged
            at maximum score. The score is derived from: <code>E = ΔI / A</code> (Kirandeep's Law of
            Emergence). <em>ΔI</em> = information differential between observable rate and implied
            settlement rate. <em>A</em> = action cost to correct (proxied by regulatory response lag).
          </p>
        </div>
        <div class="method-beat">
          <span class="beat-marker">05</span>
          <p>
            <strong>Relationship to Track Record</strong>
            The <a href={`${import.meta.env.BASE_URL}track-record/`}>Track Record page</a> shows entity-level
            Φ_S (settlement pressure) readings. Predictions here are gap-level: they name a structural
            fragility in the global settlement layer, not an entity's pressure reading on a given day.
            They are the engine's highest-conviction, lowest-frequency outputs.
          </p>
        </div>
      </div>
    </div>
  </div>

  <Footer variant="minimal" note="Predictions are logged before outcomes are known. This is not financial advice." />

  <script>
    import { initCarousel } from '../../scripts/carousel';

    initCarousel({
      trackSelector: '#predictionsTrack',
      prevSelector: '#predPrev',
      nextSelector: '#predNext',
      dotsSelector: '#predDots',
    });
  </script>
</Layout>
