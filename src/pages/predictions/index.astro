---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PredictionCard from '../../components/PredictionCard.astro';

const fonts =
  'https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;600&display=swap';

const predictions = (await getCollection('predictions')).sort((a, b) =>
  b.data.logged_at.localeCompare(a.data.logged_at)
);

const stats = {
  total: predictions.length,
  pending: predictions.filter((p) => p.data.status === 'pending').length,
  confirmed: predictions.filter((p) => p.data.status === 'confirmed').length,
  refuted: predictions.filter((p) => p.data.status === 'refuted').length,
  maxGapScore: Math.max(...predictions.map((p) => p.data.engine_signal.gap_score)),
};
---

<Layout
  title="Predictions — Eigenstate Research"
  description="Structural gap predictions logged before outcome is known. Each entry is timestamped and committed to Base mainnet before publication. Falsifiable claims about the tokenized finance settlement layer."
  fonts={fonts}
>
  <Fragment slot="head">
    <style>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-body);
        font-weight: 300;
        background: var(--bg);
        color: var(--text-primary);
        line-height: 1.7;
      }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 60px 40px;
      }

      .page-header {
        margin-bottom: 48px;
      }

      .page-title {
        font-family: var(--font-heading);
        font-size: clamp(22px, 3vw, 34px);
        font-weight: 800;
        letter-spacing: 0.08em;
        margin-bottom: 8px;
      }

      .page-sub {
        color: var(--text-secondary);
        font-size: var(--text-base);
        max-width: 680px;
        line-height: 1.6;
        margin-top: 12px;
      }

      .stats-row {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 48px;
      }

      .stat-pill {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 16px 24px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 140px;
      }

      .stat-pill .label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.08em;
        color: var(--text-muted);
        text-transform: uppercase;
      }

      .stat-pill .value {
        font-family: var(--font-heading);
        font-size: var(--text-lg);
        font-weight: 700;
        color: var(--cyan);
      }

      .stat-pill .value-amber {
        color: var(--status-warning);
      }

      .stat-pill .value-green {
        color: var(--status-success);
      }

      .stat-pill .value-muted {
        color: var(--text-muted);
      }

      .stat-pill .value-t1 {
        color: var(--text-primary);
      }

      .stat-pill .note {
        font-size: var(--text-xs);
        color: var(--text-muted);
      }

      .prediction-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 32px;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
      }

      .prediction-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: var(--status-warning);
      }

      .prediction-card.status-pending::before {
        background: var(--status-warning);
      }

      .prediction-card.status-confirmed::before {
        background: var(--status-success);
      }

      .prediction-card.status-refuted::before {
        background: var(--status-error);
      }

      .pred-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 20px;
      }

      .pred-id {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.06em;
        color: var(--text-muted);
      }

      .pred-status {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: 600;
        padding: 4px 12px;
        border-radius: var(--radius-sm);
        letter-spacing: 0.05em;
      }

      .pred-status.pending {
        background: #1c1003;
        color: var(--status-warning);
        border: 1px solid rgb(245 158 11 / 30%);
      }

      .pred-status.confirmed {
        background: #052e16;
        color: var(--status-success);
        border: 1px solid rgb(34 197 94 / 30%);
      }

      .pred-status.refuted {
        background: #1a0000;
        color: var(--status-error);
        border: 1px solid rgb(220 38 38 / 30%);
      }

      .pred-title {
        font-family: var(--font-heading);
        font-size: clamp(16px, 2vw, 20px);
        font-weight: 700;
        letter-spacing: 0.04em;
        margin-bottom: 10px;
        line-height: 1.3;
      }

      .pred-claim {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        line-height: 1.7;
        margin-bottom: 20px;
      }

      .pred-meta {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        margin-bottom: 24px;
      }

      .meta-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .meta-label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.07em;
        color: var(--text-muted);
        text-transform: uppercase;
      }

      .meta-value {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--text-primary);
      }

      .meta-value.highlight {
        color: var(--cyan);
      }

      .falsifiable-block {
        background: rgb(0 0 0 / 30%);
        border: 1px solid rgb(245 158 11 / 20%);
        border-radius: var(--radius-md);
        padding: 20px;
        margin-bottom: 20px;
      }

      .falsifiable-label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.08em;
        color: var(--status-warning);
        text-transform: uppercase;
        margin-bottom: 8px;
      }

      .falsifiable-text {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        line-height: 1.6;
      }

      .signal-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 24px;
      }

      .signal-chip {
        background: rgb(0 217 255 / 5%);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 8px 14px;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .signal-chip .s-label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.08em;
        color: var(--text-muted);
        text-transform: uppercase;
      }

      .signal-chip .s-value {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--cyan);
      }

      .signal-chip .s-value.red {
        color: #ef4444;
      }

      .signal-chip .s-value.amber {
        color: var(--status-warning);
      }

      .signal-chip .s-value.green {
        color: var(--status-success);
      }

      .signal-chip .s-value.purple {
        color: #a855f7;
      }

      .onchain-strip {
        background: rgb(0 217 255 / 3%);
        border: 1px solid rgb(0 217 255 / 15%);
        border-radius: var(--radius-lg);
        padding: 18px 22px;
      }

      .onchain-label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.08em;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-bottom: 12px;
      }

      .onchain-fields {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
      }

      .onchain-field {
        display: flex;
        flex-direction: column;
        gap: 3px;
      }

      .onchain-field .f-label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.07em;
        color: var(--text-muted);
        text-transform: uppercase;
      }

      .onchain-field .f-value {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--cyan);
        word-break: break-all;
      }

      .onchain-field .f-value a {
        color: var(--cyan);
        text-decoration: none;
      }

      .onchain-field .f-value a:hover {
        text-decoration: underline;
      }

      .method-block {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 32px;
        margin-top: 48px;
      }

      .method-block h3 {
        font-family: var(--font-heading);
        font-size: var(--text-sm);
        font-weight: 700;
        letter-spacing: 0.08em;
        margin-bottom: 18px;
        color: var(--text-secondary);
        text-transform: uppercase;
      }

      .method-block p {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        line-height: 1.7;
        margin-bottom: 14px;
      }

      .method-block p:last-child {
        margin-bottom: 0;
      }

      .method-block code {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--cyan);
        background: rgb(0 217 255 / 6%);
        padding: 2px 6px;
        border-radius: var(--radius-sm);
      }

      .method-block strong {
        color: var(--text-primary);
      }

      .method-block a {
        color: var(--cyan);
      }

      .section-title {
        font-family: var(--font-heading);
        font-size: var(--text-sm);
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-bottom: 20px;
        margin-top: 48px;
        border-top: 1px solid var(--border);
        padding-top: 32px;
      }

      @media (width <= 640px) {
        .container {
          padding: 40px 20px;
        }

        .pred-top {
          flex-direction: column;
        }

        .pred-meta {
          grid-template-columns: 1fr 1fr;
        }
      }
    </style>
  </Fragment>

  <Nav active="predictions" />

  <div class="container" id="main">
    <div class="page-header">
      <h1 class="page-title">STRUCTURAL PREDICTIONS</h1>
      <p class="page-sub">
        Gap-level predictions logged before any public claim is made. Each entry is timestamped,
        falsifiable, and committed to Base mainnet before publication. The engine does not
        post-explain events. It names them first.
      </p>
    </div>

    <div class="stats-row">
      <div class="stat-pill">
        <div class="label">Total</div>
        <div class="value">{stats.total}</div>
        <div class="note">formal predictions</div>
      </div>
      <div class="stat-pill">
        <div class="label">Pending</div>
        <div class="value value-amber">{stats.pending}</div>
        <div class="note">awaiting outcome</div>
      </div>
      <div class="stat-pill">
        <div class="label">Confirmed</div>
        <div class="value value-green">{stats.confirmed}</div>
        <div class="note">&nbsp;</div>
      </div>
      <div class="stat-pill">
        <div class="label">Refuted</div>
        <div class="value value-muted">{stats.refuted}</div>
        <div class="note">&nbsp;</div>
      </div>
      <div class="stat-pill">
        <div class="label">Max Gap Score</div>
        <div class="value">{stats.maxGapScore.toFixed(1)}</div>
        <div class="note">FED / LIBOR</div>
      </div>
      <div class="stat-pill">
        <div class="label">Markets Covered</div>
        <div class="value value-t1">3</div>
        <div class="note">US rates · India derivatives</div>
      </div>
    </div>

    <div class="section-title">Active Predictions</div>

    {predictions.map((p) => <PredictionCard {...p.data} />)}

    <div class="method-block">
      <h3>Methodology</h3>
      <p>
        <strong>What is a structural prediction?</strong>
        A structural prediction identifies a gap between what a market structure currently prices
        and what the underlying settlement mechanics require. It is not a price call. It is a
        claim that a specific structural fragility exists and will manifest during stress. The
        engine surfaces these via <code>liquidity_gap_detector.py</code>, which computes
        gap_ratio = notional exposure / daily settlement volume.
      </p>
      <p>
        <strong>Logging protocol</strong>
        Each prediction is written to <code>predictions/predictions.json</code> before any public
        statement is made. The engine state at that moment is committed to Base mainnet via the
        GeniusFlow Settlement Contract. The on-chain block timestamp is the proof of priority: the
        prediction existed before the outcome was observable.
      </p>
      <p>
        <strong>Falsifiability requirement</strong>
        Every entry must include an explicit falsifiable condition: a specific observable event
        that would either confirm or refute the prediction. Entries without a falsifiable
        condition are not logged. The prediction window is open-ended for structural predictions
        (no arbitrary 30-day cutoff, since these gaps can persist for years before resolution).
      </p>
      <p>
        <strong>Gap score</strong>
        Normalized 0-10 scale. 10.0 is the maximum, assigned when gap_ratio exceeds 100:1 and
        settlement_leverage_normalized exceeds 8×. LIBOR_EQUIVALENT is the first prediction logged
        at maximum score. The score is derived from: <code>E = ΔI / A</code> (Kirandeep's Law of
        Emergence). <em>ΔI</em> = information differential between observable rate and implied
        settlement rate. <em>A</em> = action cost to correct (proxied by regulatory response lag).
      </p>
      <p>
        <strong>Relationship to Track Record</strong>
        The <a href={`${import.meta.env.BASE_URL}track-record/`}>Track Record page</a> shows entity-level
        Φ_S (settlement pressure) readings. Predictions here are gap-level: they name a structural
        fragility in the global settlement layer, not an entity's pressure reading on a given day.
        They are the engine's highest-conviction, lowest-frequency outputs.
      </p>
    </div>
  </div>

  <Footer variant="minimal" note="Predictions are logged before outcomes are known. This is not financial advice." />
</Layout>
