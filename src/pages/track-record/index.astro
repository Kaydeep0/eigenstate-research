            points="0.0,17.0 2.1,17.2 4.3,17.4 6.4,17.0 8.6,18.2 10.7,16.8 12.9,17.7 15.0,17.5 17.1,17.5 19.3,17.7 21.4,20.8 23.6,22.5 25.7,24.7 27.9,25.6 30.0,13.9 32.1,25.2 34.3,19.4 36.4,17.7 38.6,23.5 40.7,23.6 42.9,24.6 45.0,27.7 47.1,27.6 49.3,31.0 51.4,31.3 53.6,30.9 55.7,30.9 57.9,31.1 60.0,31.4 62.1,31.4 64.3,30.9 66.4,30.9 68.6,31.4 70.7,31.1 72.9,30.8 75.0,31.8 77.1,31.7 79.3,31.8 81.4,32.0 83.6,33.6 85.7,33.6 87.9,38.3 90.0,37.9 92.1,38.2 94.3,38.2 96.4,37.9 98.6,38.1 100.7,38.1 102.9,37.9 105.0,38.0 107.1,37.3 109.3,36.8 111.4,36.5 113.6,40.9 115.7,42.8 117.9,48.9 120.0,50.4 122.1,52.1 124.3,53.2 126.4,54.1 128.6,54.7 130.7,55.2 132.9,55.8 135.0,56.0 137.1,38.0 139.3,38.5 141.4,37.8 143.6,38.2 145.7,37.9 147.9,38.3 150.0,38.3 152.1,38.2 154.3,39.7 156.4,42.8 158.6,42.8 160.7,47.9 162.9,47.8 165.0,49.7 167.1,50.2 169.3,50.2 171.4,51.0 173.6,51.1 175.7,51.4 177.9,51.5 180.0,50.5 182.1,50.7 184.3,50.9 186.4,50.9 188.6,50.8 190.7,50.6 192.9,50.8 195.0,48.9 197.1,51.0 199.3,49.8 201.4,50.5 203.6,51.3 205.7,52.8 207.9,53.2 210.0,53.3 212.1,53.8 214.3,54.2 216.4,54.9 218.6,50.6 220.7,51.0 222.9,51.1 225.0,51.3 227.1,51.5 229.3,5.8 231.4,5.0 233.6,6.3 235.7,5.0 237.9,8.3 240.0,11.3 242.1,15.2 244.3,11.3 246.4,16.0 248.6,14.4 250.7,23.7 252.9,20.4 255.0,22.7 257.1,25.1 259.3,26.3 261.4,22.7 263.6,22.3 265.7,22.8 267.9,21.7 270.0,25.0 272.1,25.7 274.3,26.4 276.4,21.9 278.6,22.8 280.7,21.3 282.9,21.3 285.0,21.3 287.1,22.3 289.3,23.1 291.4,24.2 293.6,24.9 295.7,25.3 297.9,25.0 300.0,24.4"
            fill="none"
            stroke="#2f5a63"
            stroke-width="1.5"
            stroke-linejoin="round"
            opacity="0.8"></polyline>
          <text x="2" y="58" font-size="9" fill="#71717a" font-family="JetBrains Mono">2026-03-29</text>
          <text x="298" y="58" font-size="9" fill="#71717a" font-family="JetBrains Mono" text-anchor="end"
            >2026-04-11</text
          >
        </svg>
      </div>
    </div>

    <div class="stats-secondary">
      <div class="stat-card-sm">
        <div class="stat-label">Total Cycles Logged</div>
        <div class="stat-value">141</div>
        <div class="stat-note">2026-03-29 → 2026-04-11</div>
      </div>
      <div class="stat-card-sm">
        <div class="stat-label">Coverage</div>
        <div class="stat-value">23.5%</div>
        <div class="stat-note">topology coverage (from 3.0%)</div>
      </div>
      <div class="stat-card-sm">
        <div class="stat-label">Coherence (κ)</div>
        <div class="stat-value">0.4153</div>
        <div class="stat-note">average over 14-day run</div>
      </div>
      <div class="stat-card-sm">
        <div class="stat-label">Published Claims</div>
        <div class="stat-value">11</div>
        <div class="stat-note">8 field-level, 0 infra-scale</div>
      </div>
    </div>
    </div>

    <div class="section-title">Claim History</div>

    <div class="claims-filter-bar">
      <div class="claims-search-wrap">
        <input
          type="text"
          id="claimsSearch"
          class="claims-search"
          placeholder="Search by entity name…"
          aria-label="Search claims by entity name"
        />
      </div>
      <select id="claimsStatus" class="claims-status" aria-label="Filter by outcome status">
        <option value="">All outcomes</option>
        <option value="pending">Pending</option>
        <option value="logged">Logged</option>
        <option value="confirmed">Confirmed</option>
      </select>
    </div>

    <div class="table-wrap bracket">
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Entity</th>
            <th class="th-num">Φ_S</th>
            <th class="th-num">κ</th>
            <th class="th-num">PT</th>
            <th>Direction Signal</th>
            <th>Outcome</th>
          </tr>
        </thead>
        <tbody id="claimsBody">
          <tr data-entity="TOPOLOGY_FIELD" data-status="pending">
            <td class="cell-date">2026-04-11</td>
            <td class="cell-entity">TOPOLOGY_FIELD</td>
            <td class="cell-metric-amber cell-num">3.236</td>
            <td class="cell-metric cell-num">0.5036</td>
            <td class="cell-metric cell-num">0.3630</td>
            <td><span class="signal-amber">BUILDING</span></td>
            <td><span class="status status-pending">Pending</span></td>
          </tr>
          <tr data-entity="Securities and Exchange Commission" data-status="pending">
            <td class="cell-date">2026-04-11</td>
            <td class="cell-entity">Securities and Exchange Commission</td>
            <td class="cell-metric-neutral cell-num">2.895</td>
            <td class="cell-metric cell-num">0.5036</td>
            <td class="cell-metric cell-num">0.3486</td>
            <td><span class="signal-neutral">ELEVATED</span></td>
            <td><span class="status status-pending">Pending</span></td>
          </tr>
          <tr data-entity="34539544" data-status="pending">
            <td class="cell-date">2026-04-11</td>
            <td class="cell-entity">34539544</td>
            <td class="cell-metric-amber cell-num">4.874</td>
            <td class="cell-metric cell-num">0.5036</td>
            <td class="cell-metric cell-num">0.3630</td>
            <td><span class="signal-amber">BUILDING</span></td>
            <td><span class="status status-pending">Pending</span></td>
          </tr>
          <tr data-entity="Federal Reserve" data-status="pending">
            <td class="cell-date">2026-04-11</td>
            <td class="cell-entity">Federal Reserve</td>
            <td class="cell-metric-amber cell-num">6.505</td>
            <td class="cell-metric cell-num">0.5036</td>
            <td class="cell-metric cell-num">0.3630</td>
            <td><span class="signal-amber">BUILDING</span></td>
            <td><span class="status status-pending">Pending</span></td>
          </tr>
          <tr data-entity="Ethereum" data-status="logged">
            <td class="cell-date">2026-04-11</td>
            <td class="cell-entity">
              Ethereum
              <a href={`${import.meta.env.BASE_URL}reports/ethereum-20260411/`} class="cell-link" title="View report">↗</a>
            </td>
            <td class="cell-metric-infra cell-num">521,674</td>
            <td class="cell-metric cell-num">0.0000</td>
            <td class="cell-metric cell-num">0.0000</td>
            <td><span class="signal-infra">INFRA_FLOW</span></td>
            <td><span class="status status-logged">Logged</span></td>
          </tr>
          <tr data-entity="Coinbase" data-status="logged">
            <td class="cell-date">2026-04-11</td>
            <td class="cell-entity">
              Coinbase
              <a href={`${import.meta.env.BASE_URL}reports/coinbase-20260411/`} class="cell-link" title="View report">↗</a>
            </td>
