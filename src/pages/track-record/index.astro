---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const fonts =
  'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap';
---

<Layout
  title="Prediction Track Record — Eigenstate Research"
  description="Verifiable measurement track record: settlement pressure readings, direction signals, and accuracy rate for the Eigenstate field engine. E = ΔI/A."
  fonts={fonts}
>
  <Fragment slot="head">
    <style>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-body);
        font-weight: 300;
        background: var(--bg);
        color: var(--text-primary);
        line-height: 1.7;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 60px 40px;
      }

      @media (width <= 640px) {
        .container {
          padding: 40px 20px;
        }
      }

      .eyebrow {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: 600;
        letter-spacing: 0.25em;
        color: var(--signal);
        text-transform: uppercase;
        margin-bottom: 12px;
      }

      .page-title {
        font-family: var(--font-heading);
        font-size: clamp(24px, 3vw, 36px);
        font-weight: 800;
        letter-spacing: 0.08em;
        margin-bottom: 8px;
      }

      .page-sub {
        color: var(--text-secondary);
        font-size: var(--text-base);
        margin-bottom: 48px;
        max-width: 700px;
        line-height: 1.6;
      }

      /* Wraps the stat grid so the instrument corner-bracket (this is live
         measured data, same treatment as the homepage proof-strip) frames
         the whole panel rather than sitting flush against the outer cards. */
      .stats-instrument {
        padding: 4px;
        margin-bottom: 48px;
      }

      /* Two-tier hierarchy instead of six undifferentiated tiles: the
         accuracy rate is the one number an allocator actually needs to
         trust this page, so it gets hero treatment (matches the homepage
         proof-strip's engine-tile-value.green — same "this is the trust
         signal" language). PT keeps its own wider panel since it's a trend
         chart, not a bare number, and shouldn't be squeezed to match a
         plain stat's height. Everything else is supporting context and
         recedes into a compact, muted secondary row. */
      .stats-hero-row {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 16px;
        margin-bottom: 16px;
      }

      @media (width <= 760px) {
        .stats-hero-row {
          grid-template-columns: 1fr;
        }
      }

      .stat-hero,
      .stat-chart {
        background: var(--bg-card);
        border: 1px solid var(--border-strong);
        border-radius: var(--radius-lg);
        padding: 28px 32px;
      }

      @media (width <= 480px) {
        .stat-hero,
        .stat-chart {
          padding: 20px;
        }
      }

      .stat-hero-label,
      .stat-chart-label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.08em;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-bottom: 10px;
      }

      .stat-hero-value {
        font-family: var(--font-heading);
        font-size: var(--text-4xl);
        font-weight: 700;
        line-height: 1;
        color: var(--status-success);
      }

      .stat-chart-value {
        font-family: var(--font-heading);
        font-size: var(--text-2xl);
        font-weight: 700;
        color: var(--signal);
      }

      .stat-hero-note,
      .stat-chart-note {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        margin-top: 8px;
      }

      .stat-note-negative {
        color: var(--status-error);
      }

      .pt-sparkline {
        display: block;
        width: 100%;
        height: auto;
        margin-top: 12px;
      }

      .stats-secondary {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
      }

      @media (width <= 900px) {
        .stats-secondary {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (width <= 560px) {
        .stats-secondary {
          grid-template-columns: 1fr;
        }
      }

      .stat-card-sm {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 18px 20px;
      }

      .stat-label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.08em;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-bottom: 8px;
      }

      .stat-value {
        font-family: var(--font-heading);
        font-size: var(--text-lg);
        font-weight: 700;
        color: var(--text-primary);
      }

      .stat-note {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        margin-top: 6px;
      }

      .section-title {
        font-family: var(--font-heading);
        font-size: var(--text-base);
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--text-secondary);
        text-transform: uppercase;
        margin-bottom: 20px;
        margin-top: 48px;
      }

      .claims-filter-bar {
        display: flex;
        gap: 12px;
        margin-bottom: 16px;
        flex-wrap: wrap;
      }

      .claims-search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
      }

      .claims-search-wrap::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 16px;
        width: 13px;
        height: 13px;
        transform: translateY(-50%);
        border: 1.5px solid var(--text-muted);
        border-radius: 50%;
        pointer-events: none;
      }

      .claims-search-wrap::after {
        content: '';
        position: absolute;
        top: 63%;
        left: 27px;
        width: 6px;
        height: 1.5px;
        transform: translateY(-50%) rotate(45deg);
        background: var(--text-muted);
        pointer-events: none;
      }

      .claims-search {
        width: 100%;
        font-family: var(--font-body);
        font-size: var(--text-sm);
        padding: 12px 16px 12px 38px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        color: var(--text-primary);
        transition: border-color 0.2s ease;
      }

      .claims-search::placeholder {
        color: var(--text-muted);
      }

      .claims-search:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgb(62 111 239 / 15%);
      }

      .claims-status {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        padding: 12px 16px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        color: var(--text-primary);
        cursor: pointer;
        transition: border-color 0.2s ease;
      }

      .claims-status:focus {
        outline: none;
        border-color: var(--accent);
      }

      .claims-empty {
        padding: 32px;
        text-align: center;
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--text-muted);
      }

      .table-wrap {
        overflow-x: auto;
        border: 1px solid var(--border-strong);
        border-radius: var(--radius-lg);
      }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: var(--text-sm);
      }

      thead tr {
        background: var(--bg2);
      }

      th {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text-muted);
        padding: 14px 16px;
        text-align: left;
        border-bottom: 1px solid var(--border-live);
        white-space: nowrap;
      }

      .th-num {
        text-align: right;
      }

      td {
        padding: 14px 16px;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
      }

      tr:last-child td {
        border-bottom: none;
      }

      tbody tr:nth-child(even) td {
        background: rgb(0 0 0 / 3%);
      }

      tr:hover td {
        background: rgb(148 163 184 / 6%);
      }

      .cell-date {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--text-secondary);
      }

      .cell-entity {
        font-weight: 500;
      }

      .cell-link {
        color: var(--signal);
        font-size: var(--text-xs);
        text-decoration: none;
      }

      .cell-num {
        font-variant-numeric: tabular-nums;
        text-align: right;
      }

      .cell-metric {
        font-family: var(--font-mono);
        color: var(--text-secondary);
      }

      .cell-metric-amber {
        font-family: var(--font-mono);
        color: var(--status-warning);
        font-weight: 600;
      }

      /* ELEVATED reads as emphasized neutral, not a hue — --signal stays
         reserved for verified/on-chain markers only (see status-logged),
         not a decorative severity color. */
      .cell-metric-neutral {
        font-family: var(--font-mono);
        color: var(--text-primary);
        font-weight: 600;
      }

      /* INFRA_FLOW is a different unit (cumulative volume, not pressure
         severity) — italic marks that distinction instead of reaching for
         another saturated hue. Purple was dropped: it's the skill's own
         "AI product" signal color in virtually every categorical result,
         which is exactly the generic-AI read this page was getting. */
      .cell-metric-infra {
        font-family: var(--font-mono);
        color: var(--text-muted);
        font-style: italic;
        font-weight: 600;
      }

      .cell-metric-muted {
        font-family: var(--font-mono);
        color: var(--text-muted);
        font-weight: 600;
      }

      .signal-amber {
        color: var(--status-warning);
        font-weight: 500;
      }

      .signal-neutral {
        color: var(--text-primary);
        font-weight: 600;
      }

      .signal-muted {
        color: var(--text-muted);
        font-weight: 500;
      }

      .signal-infra {
        color: var(--text-muted);
        font-style: italic;
        font-weight: 500;
      }

      /* Status dots instead of filled pill badges — a pill sized to fit
         "Pending" and one sized to fit "Quiet confirmed ✓" never align, and
         a dot doesn't have that problem since the text just flows after it. */
      .status {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: 600;
        letter-spacing: 0.03em;
        white-space: nowrap;
      }

      .status::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentcolor;
        flex-shrink: 0;
      }

      .status-pending {
        color: var(--status-warning);
      }

      .status-logged {
        color: var(--signal);
      }

      .status-confirmed {
        color: var(--status-success);
      }

      .method-block {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 32px;
        margin-top: 48px;
      }

      .method-block h3 {
        font-family: var(--font-heading);
        font-size: var(--text-base);
        font-weight: 700;
        letter-spacing: 0.08em;
        margin-bottom: 20px;
        color: var(--text-secondary);
      }

      .method-block p {
        font-size: var(--text-base);
        color: var(--text-secondary);
        line-height: 1.7;
        margin-bottom: 0;
      }

      .method-beats {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .method-beat {
        display: grid;
        grid-template-columns: 32px 1fr;
        gap: 16px;
        align-items: start;
      }

      .method-beat .beat-marker {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-weight: 600;
        color: var(--accent-dark);
        letter-spacing: 0.05em;
        padding-top: 2px;
      }

      @media (width <= 640px) {
        .method-beat {
          grid-template-columns: 24px 1fr;
          gap: 12px;
        }
      }

      .method-block code {
        font-family: var(--font-mono);
        font-size: var(--text-base);
        color: var(--signal);
        background: rgb(47 90 99 / 8%);
        padding: 2px 6px;
        border-radius: var(--radius-sm);
      }

      .verify-strip {
        background: rgb(47 90 99 / 6%);
        border: 1px solid var(--border-strong);
        border-radius: var(--radius-lg);
        padding: 20px 24px;
        margin-top: 32px;
        display: flex;
        flex-wrap: wrap;
        gap: 24px;
        align-items: center;
      }

      .verify-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .verify-label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        letter-spacing: 0.08em;
        color: var(--text-muted);
        text-transform: uppercase;
      }

      .verify-value {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--signal);
        word-break: break-all;
      }

      .verify-value-muted {
        color: var(--text-muted);
      }

      .verify-value a {
        color: var(--signal);
        text-decoration: none;
      }

      .verify-value a:hover {
        text-decoration: underline;
      }

    </style>
  </Fragment>

  <Nav active="track-record" />

  <div class="container" id="main">
    <div class="eyebrow">EIGENSTATE RESEARCH · VERIFIABLE TRACK RECORD</div>
    <h1 class="page-title">PREDICTION TRACK RECORD</h1>
    <p class="page-sub">
      The engine logs timestamped Φ_S (settlement pressure) readings for specific entities in the
      tokenized finance settlement layer. Each reading is a falsifiable claim — pressure above
      threshold predicts an event within 30 days. This page is the compiled record of every
      published claim and its measured outcome.
    </p>

    <div class="stats-instrument bracket">
    <div class="stats-hero-row">
      <div class="stat-hero">
        <div class="stat-hero-label">Signal Accuracy</div>
        <div class="stat-hero-value">100.0%</div>
        <div class="stat-hero-note">4 of 4 assessable signals validated</div>
      </div>
      <div class="stat-chart">
        <div class="stat-chart-label">Protocol Truth (PT)</div>
        <div class="stat-chart-value">0.3466</div>
        <div class="stat-chart-note">PT moved <span class="stat-note-negative">-0.0788</span> over 14 days</div>
        <svg width="300" height="60" viewBox="0 0 300 60" class="pt-sparkline">
