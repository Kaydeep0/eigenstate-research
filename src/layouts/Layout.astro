---
import '../styles/tokens.css';
import '../styles/buttons.css';
import '../styles/motion.css';
import '../styles/instruments.css';

interface Props {
  title: string;
  description?: string;
  fonts?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const { title, description, fonts, ogImage, ogType = 'website' } = Astro.props;
const base = import.meta.env.BASE_URL;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const resolvedOgImage = new URL(ogImage ?? `${base}assets/images/chart.png`, Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Eigenstate Research" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={resolvedOgImage} />

    {
      fonts && (
        <>
          <link rel="preconnect" href="https://fonts.googleapis.com" />
          <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
          <link href={fonts} rel="stylesheet" />
        </>
      )
    }
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -48px;
    left: 0;
    z-index: 10000;
    background: #5b96a0;
    color: #030712;
    padding: 10px 18px;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: top 0.2s ease;
  }

  .skip-link:focus {
    top: 0;
  }

  /* stylelint-disable declaration-no-important -- global a11y override must win over any component-level animation/transition */
  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
  /* stylelint-enable declaration-no-important */
</style>
