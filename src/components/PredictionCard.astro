---
interface EngineSignal {
  gap_score: number;
  gap_ratio: number;
  delta_i: number;
  settlement_leverage_normalized?: number;
  settlement_leverage?: number;
  days_to_expiry: number;
  flag: string;
  curl_confirmed: boolean;
  curl_confirmed_source?: string;
  overlay_entities: string[];
  primary_entity: string;
}

interface OnChainProof {
  claim_id: number;
  block_number: number;
  committed_at: string;
  vault_fingerprint: string;
  tx_hash: string;
  basescan_url: string;
}

interface Props {
  id: string;
  status: 'pending' | 'confirmed' | 'refuted';
  logged_at: string;
  title: string;
  claim: string;
  falsifiable_condition: string;
  gap_id: string;
  engine_signal: EngineSignal;
  on_chain_proof: OnChainProof;
}

const { id, status, logged_at, title, claim, falsifiable_condition, gap_id, engine_signal, on_chain_proof } =
  Astro.props;

const loggedDate = new Date(logged_at);
const loggedDisplay = isNaN(loggedDate.getTime())
  ? logged_at
  : loggedDate.toISOString().slice(0, 10);

const leverage = engine_signal.settlement_leverage_normalized ?? engine_signal.settlement_leverage;
const txShort = `${on_chain_proof.tx_hash.slice(0, 8)}...${on_chain_proof.tx_hash.slice(-4)}`;
---

<div class={`prediction-card status-${status}`}>
  <div class="pred-top">
    <div class="pred-id">ID: {id} &nbsp;·&nbsp; Logged {loggedDisplay}</div>
    <span class={`pred-status ${status}`}>{status.toUpperCase()}</span>
  </div>

  <h2 class="pred-title">{title}</h2>

  <p class="pred-claim">{claim}</p>

  <div class="falsifiable-block">
    <div class="falsifiable-label">Falsifiable Condition</div>
    <div class="falsifiable-text">{falsifiable_condition}</div>
  </div>

  <div class="pred-meta">
    <div class="meta-item">
      <div class="meta-label">Primary Entity</div>
      <div class="meta-value highlight">{engine_signal.primary_entity}</div>
    </div>
    <div class="meta-item">
      <div class="meta-label">Gap ID</div>
      <div class="meta-value">{gap_id}</div>
    </div>
    <div class="meta-item">
      <div class="meta-label">Days to Expiry</div>
      <div class="meta-value">{engine_signal.days_to_expiry}</div>
    </div>
  </div>

  <div class="signal-grid">
    <div class="signal-chip">
      <div class="s-label">Gap Score</div>
      <div class="s-value red">{engine_signal.gap_score.toFixed(1)} / 10</div>
    </div>
    <div class="signal-chip">
      <div class="s-label">Gap Ratio</div>
      <div class="s-value amber">{engine_signal.gap_ratio.toFixed(0)}:1</div>
    </div>
    {
      leverage != null && (
        <div class="signal-chip">
          <div class="s-label">Settlement Leverage</div>
          <div class="s-value amber">{leverage}×</div>
        </div>
      )
    }
    <div class="signal-chip">
      <div class="s-label">Delta_I</div>
      <div class="s-value">{engine_signal.delta_i}</div>
    </div>
    <div class="signal-chip">
      <div class="s-label">Curl Confirmed</div>
      {
        engine_signal.curl_confirmed_source ? (
          <div class="s-value amber" title={engine_signal.curl_confirmed_source}>
            DETECTOR FLAG
          </div>
        ) : (
          <div class="s-value green">YES</div>
        )
      }
    </div>
    <div class="signal-chip">
      <div class="s-label">Flag</div>
      <div class="s-value purple">{engine_signal.flag}</div>
    </div>
  </div>

  <div class="onchain-strip bracket">
    <div class="onchain-label">On-Chain Proof (Base Mainnet, logged before publication)</div>
    <div class="onchain-fields">
      <div class="onchain-field"><div class="f-label">Claim ID</div><div class="f-value">{on_chain_proof.claim_id}</div></div>
      <div class="onchain-field"><div class="f-label">Block</div><div class="f-value">{on_chain_proof.block_number}</div></div>
      <div class="onchain-field">
        <div class="f-label">Committed At</div>
        <div class="f-value">{new Date(on_chain_proof.committed_at).toISOString().slice(0, 16).replace('T', ' ')} UTC</div>
      </div>
      <div class="onchain-field">
        <div class="f-label">Vault Fingerprint</div><div class="f-value">{on_chain_proof.vault_fingerprint}</div>
      </div>
      <div class="onchain-field">
        <div class="f-label">Transaction</div>
        <div class="f-value">
          <a href={on_chain_proof.basescan_url} target="_blank" rel="noopener">{txShort} ↗</a>
        </div>
      </div>
      <div class="onchain-field">
        <div class="f-label">Overlay Entities</div>
        <div class="f-value">{engine_signal.overlay_entities.join(', ')}</div>
      </div>
    </div>
  </div>
</div>

<style>
  /*
    Moved here from predictions/index.astro's own <style> block: Astro's
    style scoping doesn't reach into markup rendered by a child component
    (same class of bug found earlier in Nav.astro/Footer.astro), so this CSS
    was silently never applying to any of these rendered elements.
  */
  .prediction-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
  }

  .prediction-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--status-warning);
  }

  .prediction-card.status-pending::before {
    background: var(--status-warning);
  }

  .prediction-card.status-confirmed::before {
    background: var(--status-success);
  }

  .prediction-card.status-refuted::before {
    background: var(--status-error);
  }

  .pred-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 20px;
  }

  .pred-id {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  .pred-status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 4px 12px;
    border-radius: var(--radius-sm);
    letter-spacing: 0.05em;
  }

  .pred-status.pending {
    background: #1c1003;
    color: var(--status-warning);
    border: 1px solid rgb(245 158 11 / 30%);
  }

  .pred-status.confirmed {
    background: #052e16;
    color: var(--status-success);
    border: 1px solid rgb(34 197 94 / 30%);
  }

  .pred-status.refuted {
    background: #1a0000;
    color: var(--status-error);
    border: 1px solid rgb(220 38 38 / 30%);
  }

  .pred-title {
    font-family: var(--font-heading);
    font-size: clamp(16px, 2vw, 20px);
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .pred-claim {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .pred-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.07em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .meta-value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-primary);
  }

  .meta-value.highlight {
    color: var(--cyan);
  }

  .falsifiable-block {
    background: rgb(0 0 0 / 30%);
    border: 1px solid rgb(245 158 11 / 20%);
    border-radius: var(--radius-md);
    padding: 20px;
    margin-bottom: 20px;
  }

  .falsifiable-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    color: var(--status-warning);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .falsifiable-text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .signal-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 24px;
  }

  .signal-chip {
    background: rgb(0 217 255 / 5%);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 8px 14px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .signal-chip .s-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .signal-chip .s-value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--cyan);
  }

  .signal-chip .s-value.red {
    color: #ef4444;
  }

  .signal-chip .s-value.amber {
    color: var(--status-warning);
  }

  .signal-chip .s-value.green {
    color: var(--status-success);
  }

  .signal-chip .s-value.purple {
    color: #a855f7;
  }

  .onchain-strip {
    background: rgb(0 217 255 / 3%);
    border: 1px solid rgb(0 217 255 / 15%);
    border-radius: var(--radius-lg);
    padding: 18px 22px;
  }

  .onchain-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .onchain-fields {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }

  .onchain-field {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .onchain-field .f-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.07em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .onchain-field .f-value {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--cyan);
    word-break: break-all;
  }

  .onchain-field .f-value a {
    color: var(--cyan);
    text-decoration: none;
  }

  .onchain-field .f-value a:hover {
    text-decoration: underline;
  }
</style>
