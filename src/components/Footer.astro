      <div class="footer-inner">
        <div class="footer-left">
          <p class="footer-logo">EIGENSTATE</p>
          <p class="footer-copy">© 2026 Eigenstate Research · Kirandeep Kaur Sekhon</p>
        </div>
        <div class="footer-right">
          <div class="footer-links">
            <a href="https://paragraph.com/@eigenstate" target="_blank" rel="noopener">Paragraph</a>
            <a href="https://github.com/Kaydeep0/eigenstate-research" target="_blank" rel="noopener">GitHub</a>
            <a href="https://geniusflow-rwa.vercel.app">Registry</a>
          </div>
          <div class="footer-links">
            <a href="https://farcaster.xyz/kdeep34539544" target="_blank" rel="noopener">Farcaster @kdeep34539544</a>
            <a href="https://x.com/GeniusFlow_" target="_blank" rel="noopener">X @GeniusFlow_</a>
            <a href="https://www.linkedin.com/in/ksekhon44/" target="_blank" rel="noopener">LinkedIn</a>
            <a href="https://medium.com/@kiran_43771" target="_blank" rel="noopener">Medium</a>
            <a href="mailto:ksekhon9851@Gmail.com">ksekhon9851@Gmail.com</a>
          </div>
          <div class="footer-links footer-links-muted">
            <a
              href="https://www.linkedin.com/build-relation/newsletter-follow?entityUrn=7054180694628995073"
              target="_blank"
              rel="noopener"
            >
              Money in Motion ↗
            </a>
            <a
              href="https://www.linkedin.com/build-relation/newsletter-follow?entityUrn=7273059005898338305"
              target="_blank"
              rel="noopener"
            >
              Bitcoin &amp; Digital Assets Talk ↗
            </a>
          </div>
          <p class="footer-eq">
            <a href="https://doi.org/10.5281/zenodo.18413995" target="_blank" rel="noopener" class="footer-eq-link">
              E = ΔI/A
