}

<style>
  /*
    Astro's style scoping doesn't reach into markup rendered by a parent's
    \3c style> block, so this must be self-contained here — var(--token) still
    resolves fine since tokens.css is loaded globally by Layout.astro.
  */
  .site-footer {
    background: var(--bg2);
    border-top: 1px solid var(--border);
    padding: 48px 40px;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    flex-wrap: wrap;
  }

  .footer-left .footer-logo {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .footer-left .footer-copy {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .footer-right {
    text-align: right;
  }

  .footer-links {
    display: flex;
    gap: 18px;
    justify-content: flex-end;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--cyan);
  }

  .footer-links-muted {
    opacity: 0.6;
    font-size: var(--text-xs);
  }

  .footer-eq {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--cyan-dim);
    margin-top: 10px;
  }

  .footer-eq-link {
    color: inherit;
    text-decoration: none;
  }

  .footer {
    margin-top: 80px;
    padding: 32px 40px;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .footer p {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .footer-note {
    margin-top: 6px;
  }

  @media (width <= 640px) {
    .site-footer {
      padding: 36px 20px;
    }

    .footer-inner {
      flex-direction: column;
    }

    .footer-right {
      text-align: left;
    }

    .footer-eq {
      text-align: left;
    }
  }
</style>
